{
  "name": "tavvet/tavvet-doctrine-prefix-bundle",
  "type": "symfony-bundle",
  "description": "Bundle for Symfony 7 and 8 to add a prefix to tables and columns database",
  "keywords": ["doctrine", "symfony", "symfony7", "symfony8", "bundle", "tavvet", "prefix", "table", "column"],
  "homepage": "https://github.com/tavvet/TavvetDoctrinePrefixBundle",
  "license": "MIT",
  "authors": [
    {
      "name": "Anton Rudakov",
      "homepage": "https://github.com/tavvet"
    }
  ],
  "require": {
    "php": "^8.2",
    "symfony/framework-bundle": "^7.0 || ^8.0",
    "symfony/yaml": "^7.0 || ^8.0",
    "doctrine/orm": "~3.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "doctrine/doctrine-bundle": "^2.12 || ^3.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Tavvet\\DoctrinePrefixBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tavvet\\DoctrinePrefixBundle\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
